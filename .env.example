# CRAFT-ON — root env template for the local docker-compose stack (db + api + web).
# Copy to `.env` for local dev. NEVER commit a real `.env` (it is gitignored).
# In GCP these come from Secret Manager / Cloud Run env (see docs/07-config-and-flags.md).
#
# The subprojects also keep their own examples (api/.env.example, web/.env.example)
# for running a single service outside compose; this root file drives `make up`.

# ── API (backend) ─────────────────────────────────────────────────────────────
CRAFTON_ENV=local                 # local | dev | staging | prod
CRAFTON_LOG_LEVEL=INFO
CRAFTON_DEBUG=true

# Auth: "fake" for local/dev/tests (no GCP), "firebase" for real OTP verification.
CRAFTON_AUTH_MODE=fake
# Firebase project id (real verifier only).
CRAFTON_FIREBASE_PROJECT_ID=crafton-dev-500709

# Storage: "fake" locally (no GCS); "gcs" in the cloud.
CRAFTON_STORAGE_MODE=fake
CRAFTON_GCS_BUCKET=crafton-dev-500709-uploads

# i18n
CRAFTON_DEFAULT_LANGUAGE=ja
CRAFTON_SUPPORTED_LANGUAGES=ja,en

# Business-config overrides (optional): CRAFTON_CFG__<KEY>, JSON-encoded.
# Precedence: app_config DB row > CRAFTON_CFG__<KEY> env > built-in default (docs/07).
# CRAFTON_CFG__PLATFORM_FEE_PER_MATCH=3000
# CRAFTON_CFG__SERVICE_AREA_ENFORCE=false

# NOTE: CRAFTON_DATABASE_URL is set by docker-compose to point at the `db` service.
# Override it here only when running the api outside compose.

# ── Web (frontend) ────────────────────────────────────────────────────────────
# Base URL of the api as seen from the host browser (compose maps it to :58000).
NEXT_PUBLIC_API_BASE_URL=http://localhost:58000
NEXT_PUBLIC_AUTH_MODE=fake
# Firebase web config (only when NEXT_PUBLIC_AUTH_MODE=firebase):
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=crafton-dev-500709
