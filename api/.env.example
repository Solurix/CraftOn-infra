# CRAFT-ON API — example environment.
# Copy to `.env` for local dev. NEVER commit a real `.env` (it is gitignored).
# In GCP, these are injected from Secret Manager / Cloud Run env (see docs/07).

# --- App ---
CRAFTON_ENV=local                 # local | dev | staging | prod
CRAFTON_LOG_LEVEL=INFO
CRAFTON_DEBUG=true

# --- Database (PostgreSQL / Cloud SQL) ---
# SQLAlchemy URL. Local dev uses the docker-compose Postgres below.
CRAFTON_DATABASE_URL=postgresql+psycopg://crafton:crafton@localhost:5432/crafton

# --- Auth (Firebase) ---
# auth_mode: "fake" for local/dev/tests (no GCP needed) or "firebase" for real
# Firebase ID-token verification (requires the `firebase` extra + credentials).
CRAFTON_AUTH_MODE=fake
# Firebase project id — used by the real verifier to check the token audience.
CRAFTON_FIREBASE_PROJECT_ID=crafton-dev-500709
# Path to a service-account JSON for firebase-admin (real verifier only).
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-sa.json

# --- Cloud Storage (documents) — wired in build-order step 2 ---
CRAFTON_GCS_BUCKET=crafton-dev-500709-uploads
CRAFTON_SIGNED_URL_TTL_SECONDS=900

# --- i18n ---
CRAFTON_DEFAULT_LANGUAGE=ja
CRAFTON_SUPPORTED_LANGUAGES=ja,en

# --- Business config overrides (optional) ---
# Any business knob from docs/07 can be overridden via an env var named
# CRAFTON_CFG__<KEY>, JSON-encoded. Precedence is:
#   app_config DB row  >  CRAFTON_CFG__<KEY> env  >  built-in default.
# Examples:
# CRAFTON_CFG__PLATFORM_FEE_PER_MATCH=3000
# CRAFTON_CFG__SERVICE_AREA_ENFORCE=false
# CRAFTON_CFG__SERVICE_AREA_PREFECTURES=["Tokyo","Kanagawa","Saitama","Chiba"]
