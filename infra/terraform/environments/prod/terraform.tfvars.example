# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars (gitignored).
# db_password is best provided via TF_VAR_db_password or a generated secret.

project_id          = "your-gcp-project-id-prod"
region              = "asia-northeast1"
uploads_bucket_name = "crafton-uploads-prod-CHANGE_ME"
# db_password       = "set-via-TF_VAR_db_password-instead"
