# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars (gitignored).
# db_password is best provided via TF_VAR_db_password env var or a gitignored *.auto.tfvars.

project_id          = "your-gcp-project-id-dev"
region              = "asia-northeast1"
uploads_bucket_name = "crafton-uploads-dev-CHANGE_ME"
# db_password       = "set-via-TF_VAR_db_password-instead"
